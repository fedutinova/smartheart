OPENAI_API_KEY=<your-key>

HTTP_ADDR=:8081

JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
JWT_ISSUER=smartheart
JWT_TTL_ACCESS=15m
JWT_TTL_REFRESH=168h

QUEUE_WORKERS=4
QUEUE_BUFFER=1024
JOB_MAX_DURATION=5m

DATABASE_URL=postgres://user:password@localhost:5432/smartheart?sslmode=disable
REDIS_URL=redis://localhost:6379

STORAGE_MODE=local # Options: local, s3, aws, localstack

# Local Storage Configuration (when STORAGE_MODE=local)
LOCAL_STORAGE_DIR=./uploads
LOCAL_STORAGE_URL=http://localhost:8081/files

# AWS S3 Configuration (when STORAGE_MODE=s3/aws/localstack)
S3_BUCKET=smartheart-files
S3_ENDPOINT=http://localhost:4566  # Empty for real AWS
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true  # true for LocalStack, false for AWS
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# --- RAG Pipeline ---
LLM_API_KEY=<your-key>          # OpenAI API key for RAG answers
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000

RAG_URL=http://localhost:8000   # RAG service URL (for Go backend)
ADMIN_API_KEY=                  # HMAC key for /admin/reindex

# RAG chunking (defaults are fine for most cases)
# RAG_CHUNK_TARGET=1900
# RAG_CHUNK_MIN=1400
# RAG_CHUNK_MAX=2600
# RAG_CHUNK_OVERLAP=250

# RAG search tuning
# RAG_RRF_K=60.0
# RAG_RRF_W_VECTOR=1.0
# RAG_RRF_W_BM25=1.0

# RAG performance
# RAG_EMBED_MODEL=intfloat/multilingual-e5-base
# RAG_EMBED_BATCH_SIZE=64
# RAG_QUERY_TIMEOUT=90

# RAG storage paths (inside container)
# RAG_SOURCE_DIR=documents
# RAG_CHROMA_PATH=./chroma_db_4
# RAG_COLLECTION_NAME=cardio_docs_hybrid

# --- Payments ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:3000/dashboard
YOOKASSA_PRICE_KOPECKS=4900
YOOKASSA_SUBSCRIPTION_PRICE_KOPECKS=9900

# --- Quotas & Rate Limiting ---
QUOTA_DAILY_LIMIT=5
RATE_LIMIT_RPM=100

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Cookie (refresh token) ---
COOKIE_SECURE=false        # true in production (requires HTTPS)
# COOKIE_DOMAIN=            # empty = origin host only; set for cross-subdomain
