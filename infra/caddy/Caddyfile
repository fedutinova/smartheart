{
	email admin@{$DOMAIN_NAME}
	# Caddy automatically manages HTTPS certificates via Let's Encrypt
}

# === Redirect HTTP to HTTPS ===

http://{$DOMAIN_NAME} {
	redir https://{$DOMAIN_NAME}{uri} permanent
}

http://www.{$DOMAIN_NAME} {
	redir https://www.{$DOMAIN_NAME}{uri} permanent
}

http://api.{$DOMAIN_NAME} {
	redir https://api.{$DOMAIN_NAME}{uri} permanent
}

# === Primary domain (HTTPS) ===

{$DOMAIN_NAME}, www.{$DOMAIN_NAME} {
	root * /var/www/frontend
	try_files {path} /index.html
	file_server
	encode gzip

	# Hashed assets — cache aggressively (1 year)
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# HTML — never cache so users always get fresh chunk references
	@html path / /index.html
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	# Security headers
	header {
		# Prevent MIME type sniffing
		X-Content-Type-Options "nosniff"
		# Prevent framing in other sites
		X-Frame-Options "DENY"
		# Enable XSS protection in older browsers
		X-XSS-Protection "1; mode=block"
		# Control referrer information
		Referrer-Policy "strict-origin-when-cross-origin"
		# HSTS: Force HTTPS for 1 year, include subdomains
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		# Permissions Policy (formerly Feature Policy)
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
	}
}

# === API domain (HTTPS) ===

api.{$DOMAIN_NAME} {
	reverse_proxy app:8080 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	# Security headers for API
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}
}
